<html lang="{{LANG_CODE}}">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{{META.TITLE}}</title>
<meta name="description" content="{{META.DESCRIPTION}}" />
