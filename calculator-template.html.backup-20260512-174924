<script>
// Burger + lang switcher
(function(){
  var burger = document.getElementById('navBurger');
  var menu = document.getElementById('mobileMenu');
  if(burger && menu){
    burger.addEventListener('click', function(){
      var open = menu.classList.toggle('open');
      burger.setAttribute('aria-expanded', open ? 'true' : 'false');
      document.body.style.overflow = open ? 'hidden' : '';
    });
    menu.addEventListener('click', function(e){ if(e.target.tagName === 'A'){ menu.classList.remove('open'); burger.setAttribute('aria-expanded','false'); document.body.style.overflow=''; } });
  }
  var ls = document.getElementById('langSwitcher');
  var lsBtn = document.getElementById('langSwitcherBtn');
  if(ls && lsBtn){
    lsBtn.addEventListener('click', function(e){ e.stopPropagation(); ls.classList.toggle('open'); });
    document.addEventListener('click', function(){ ls.classList.remove('open'); });
  }
})();

// CALCULATOR
(function(){
  var I18N = {{CALC_I18N_JSON}};

  var LF={ws_fin:{beginner:1.10,intermediate:1.03,gevorderd:0.92},ws_foil:{beginner:1.10,intermediate:0.85,gevorderd:0.70},wing:{beginner:1.10,intermediate:0.78,gevorderd:0.60},kite:{beginner:1.10,intermediate:1.03,gevorderd:0.85}};
  var WF={ws_fin:{low:1.07,mid:1.0,high:0.93},ws_foil:{low:1.10,mid:1.0,high:0.90},wing:{low:1.10,mid:1.0,high:0.90},kite:{low:1.0,mid:1.0,high:1.0}};
  var FOIL_SETUP={ws_foil:{beginner:{fuselage:'75-85',mast:'70-80'},intermediate:{fuselage:'65-75',mast:'75-85'},gevorderd:{fuselage:'55-65',mast:'80-90'}},wing:{beginner:{fuselage:'70-80',mast:'65-75'},intermediate:{fuselage:'60-70',mast:'70-80'},gevorderd:{fuselage:'50-60',mast:'75-85'}},kite:{beginner:{fuselage:'60-70',mast:'55-65'},intermediate:{fuselage:'50-60',mast:'60-70'},gevorderd:{fuselage:'40-55',mast:'65-80'}}};

  var lvl='intermediate', wnd='mid';
  function $(id){return document.getElementById(id);}
  function num(x,def){var v=parseFloat(String(x||'').replace(',','.'));return isNaN(v)?def:v;}
  function clamp(v,a,b){return Math.max(a,Math.min(b,v));}

  function setActive(group,val){
    var btns=document.querySelectorAll('#'+group+' .calc-pill');
    for(var i=0;i<btns.length;i++) btns[i].classList.toggle('on', btns[i].dataset.v===val);
  }

  function updateUI(){
    var d=$('calcDisc').value;
    $('calcStyleGroup').style.display=(d==='ws_fin')?'block':'none';
    $('calcWidthGroup').style.display=(d.indexOf('ws')===0)?'block':'none';
    $('calcWindGroup').style.display=(d==='kite')?'none':'block';
    $('calcSailGroup').style.display=(d==='kite')?'none':'block';
    $('calcWeedGroup').style.display=(d==='ws_fin')?'flex':'none';
    $('calcFoilSetup').style.display=(d==='ws_fin')?'none':'block';
    var sailLabel=$('calcSailLabel');
    var sailInp=$('calcSail');
    if(d==='wing'){
      sailLabel.textContent=I18N.WING_SIZE;
      sailInp.placeholder=I18N.WING_PH;
    } else {
      sailLabel.textContent=I18N.SAIL;
      sailInp.placeholder=I18N.SAIL_PH;
    }
    $('calcWindLabel').textContent=(d==='ws_fin')?I18N.WIND:I18N.RIDER;
    var wb=document.querySelectorAll('#calcWindPills .calc-pill');
    if(wb.length===3){
      if(d==='ws_fin'){wb[0].textContent=I18N.WIND_LOW;wb[1].textContent=I18N.WIND_MID;wb[2].textContent=I18N.WIND_HIGH;}
      else if(d==='kite'){wb[0].textContent='';wb[1].textContent='';wb[2].textContent='';}
      else {wb[0].textContent=I18N.RIDER_LIGHT;wb[1].textContent=I18N.RIDER_ALLROUND;wb[2].textContent=I18N.RIDER_STRONG;}
    }
    calc();
  }

  function calc(){
    var d=$('calcDisc').value;
    var wRaw=$('calcWeight').value;
    var sRaw=$('calcSail').value;
    var bRaw=$('calcWidth').value;
    var sd=$('calcStyle').value;
    var weed=$('calcWeed').checked;
    var needsSail=(d!=='kite');
    if(!wRaw||(needsSail&&!sRaw)){render(null);return;}
    var w=clamp(num(wRaw,80),30,150);
    var s=clamp(num(sRaw,7.5),2,13);
    var b=clamp(num(bRaw,70),45,105);
    var resA,resB,resC,spanA,spanB,spanC,warn='',unit='cm';
    if(d==='ws_fin'){
      var base=((s*4.0)+(b-70)*0.20+(w-80)*0.22+10.5)*LF.ws_fin[lvl]*WF.ws_fin[wnd];
      var dm=(sd==='slalom')?1.05:(sd==='freeride')?1.01:(sd==='wave')?0.73:0.68;
      var fb=base*dm;
      var wfm={slalom:0.82,freeride:0.82,wave:0.90,freestyle:0.90};
      resA=weed?fb*(wfm[sd]||0.82):fb;
      resB=resA*0.95;
      var maxR=(sd==='slalom')?0.70:0.65;
      var maxL=b*maxR;
      if(bRaw&&resA>maxL){resA=maxL;warn=I18N.WARN_MAX.replace('{len}',Math.round(maxL)).replace('{board}',b);}
      if(bRaw&&resB>maxL)resB=maxL;
      var minL=(sd==='freeride'||sd==='slalom')?20:14;
      if(resA<minL){resA=minL;warn=I18N.WARN_MIN.replace('{len}',minL).replace('{style}',sd);}
      if(resB<minL)resB=minL;
    } else if(d==='ws_foil'){
      unit='cm²';
      resA=((w*10)+(s*100))*LF.ws_foil[lvl]*WF.ws_foil[wnd];
      resC=resA*0.90;resB=resA*0.75;
      spanA=Math.sqrt(resA*5.0);spanC=Math.sqrt(resC*7.0);spanB=Math.sqrt(resB*10.0);
      if(spanB>b*1.45)warn=I18N.WARN_FOIL_WIDE;
    } else if(d==='wing'){
      unit='cm²';
      resA=((w*20)+(s*45))*LF.wing[lvl]*WF.wing[wnd];
      resC=resA*0.85;resB=resA*0.70;
      spanA=Math.sqrt(resA*5.0);spanC=Math.sqrt(resC*7.5);spanB=Math.sqrt(resB*10.0);
    } else if(d==='kite'){
      unit='cm²';
      resA=(w*9+150)*LF.kite[lvl];
      resC=resA*0.85;resB=resA*0.65;
      spanA=Math.sqrt(resA*4.5);spanC=Math.sqrt(resC*6.0);spanB=Math.sqrt(resB*9.0);
    }
    render({d:d,resA:resA,resB:resB,resC:resC,spanA:spanA,spanB:spanB,spanC:spanC,warn:warn,unit:unit});
    updateFoilSetup();
  }

  function render(r){
    var w=$('calcWarn');var res=$('calcResults');
    if(!r){res.innerHTML='';w.style.display='none';return;}
    if(r.warn){w.style.display='flex';$('calcWarnTxt').textContent=r.warn;} else w.style.display='none';
    var L;
    if(r.d==='ws_fin') L=[[I18N.RES_STD,I18N.RES_STD_SUB],[I18N.RES_PERF,I18N.RES_PERF_SUB]];
    else if(r.d==='ws_foil') L=[['Low Aspect','freeride'],['Mid Aspect','freerace'],['High Aspect','slalom / race']];
    else if(r.d==='wing') L=[['Low Aspect','freeride'],['Mid Aspect','allround / freestyle'],['High Aspect','downwind / race']];
    else L=[['Low Aspect','freeride'],['Mid Aspect','freestyle / big air'],['High Aspect','race']];
    function card(lbl,sub,val,span){
      return '<div class="calc-res"><div class="calc-res-lbl">'+lbl+'<div class="calc-res-sub">'+sub+'</div></div><div class="calc-res-val">'+Math.round(val)+'<span class="calc-res-unit">'+r.unit+'</span></div>'+(span?'<span class="calc-res-span">'+Math.round(span)+' cm span</span>':'')+'</div>';
    }
    if(r.d==='ws_fin'){
      res.innerHTML=card(L[0][0],L[0][1],r.resA,null)+card(L[1][0],L[1][1],r.resB,null);
    } else {
      res.innerHTML=card(L[0][0],L[0][1],r.resA,r.spanA)+card(L[1][0],L[1][1],r.resC,r.spanC)+card(L[2][0],L[2][1],r.resB,r.spanB);
    }
  }

  function updateFoilSetup(){
    var d=$('calcDisc').value;
    var block=$('calcFoilSetup');
    var content=$('calcFoilSetupContent');
    if(!FOIL_SETUP[d]){block.style.display='none';return;}
    block.style.display='block';
    var data=FOIL_SETUP[d];
    var levels=[['beginner',I18N.BEGINNER],['intermediate',I18N.INTERMEDIATE],['gevorderd',I18N.ADVANCED]];
    var html='<table class="calc-foil-table"><thead><tr><th>'+I18N.LEVEL+'</th><th>'+I18N.FUSELAGE+'</th><th>'+I18N.MAST+'</th></tr></thead><tbody>';
    for(var i=0;i<levels.length;i++){
      var k=levels[i][0];var lbl=levels[i][1];var info=data[k];
      var cls=(k===lvl)?' class="current"':'';
      html+='<tr'+cls+'><td><span class="calc-foil-dot"></span>'+lbl+'</td><td>'+info.fuselage+' cm</td><td>'+info.mast+' cm</td></tr>';
    }
    html+='</tbody></table><p style="margin:10px 0 0;font-size:12px;color:#64748b;line-height:1.55">'+I18N.FOIL_NOTE+'</p>';
    content.innerHTML=html;
  }

  // Event listeners
  ['calcDisc','calcStyle','calcWeight','calcSail','calcWidth','calcWeed'].forEach(function(id){
    var e=$(id);if(!e)return;
    var ev=(id==='calcWeed')?'change':'input';
    e.addEventListener(ev,function(){ if(id==='calcDisc')updateUI(); else calc(); });
  });
  document.querySelectorAll('#calcLevelPills .calc-pill').forEach(function(b){
    b.addEventListener('click',function(){lvl=b.dataset.v;setActive('calcLevelPills',lvl);calc();});
  });
  document.querySelectorAll('#calcWindPills .calc-pill').forEach(function(b){
    b.addEventListener('click',function(){wnd=b.dataset.v;setActive('calcWindPills',wnd);calc();});
  });

  updateUI();
})();
</script>

